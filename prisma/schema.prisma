model uvki_cart {
  cart_id      Int      @id @default(autoincrement()) @db.UnsignedInt
  api_id       Int
  customer_id  Int
  session_id   String   @db.VarChar(32)
  product_id   Int
  recurring_id Int
  option       String   @db.Text
  quantity     Int
  date_added   DateTime @db.DateTime(0)

  uvki_product uvki_product? @relation(fields: [product_id], references: [product_id])
  
  @@index([api_id, customer_id, session_id, product_id, recurring_id], map: "cart_id")
}

model uvki_category {
  category_id   Int      @id @default(autoincrement())
