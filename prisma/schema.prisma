  link      String   @db.VarChar(321)
  fixedlink String   @db.VarChar(321)
  date      DateTime @db.DateTime(0)

  @@ignore
}

model uvki_banner {
  banner_id Int     @id @default(autoincrement())
  name      String  @db.VarChar(64)
  status    Boolean
}

