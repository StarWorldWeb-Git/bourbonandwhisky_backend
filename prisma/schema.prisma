generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model ks_manager_login {
  id       Int    @id @default(autoincrement())
  username String @unique(map: "username") @db.VarChar(255)
  password String @db.VarChar(255)
}

model ks_order_employees {
  id          Int                     @id @default(autoincrement())
  employee_id String                  @unique(map: "employee_id") @db.VarChar(50)
  name        String                  @db.VarChar(100)
  email       String                  @unique(map: "email") @db.VarChar(100)
  password    String                  @db.VarChar(255)
  details     String?                 @db.Text
  created_at  DateTime?               @default(now()) @db.Timestamp(0)
  status      Boolean?                @default(true)
  role        ks_order_employees_role @default(supervisor)
  otp_code    String?                 @db.VarChar(10)
  otp_expiry  Int?
}

model ks_orders_admin_login {
  id         Int     @id @default(autoincrement())
  username   String  @unique(map: "username") @db.VarChar(100)
  password   String  @db.VarChar(255)
  otp_code   String? @db.VarChar(10)
  otp_expiry Int?
}

model ks_orders_employee_login {
  id                 Int     @id @default(autoincrement()) @db.UnsignedInt
  username           String  @unique(map: "username") @db.VarChar(100)
  password           String  @db.VarChar(255)
  reset_token        String? @db.VarChar(255)
  reset_token_expiry Int?
}

model ks_print_logs {
  id            Int      @id @default(autoincrement())
  employee_id   Int
  employee_name String?  @db.VarChar(100)
  order_id      Int
  print_type    String   @db.VarChar(200)
  printed_at    DateTime @default(now()) @db.DateTime(0)
}

model ks_uvki_order {
  id                  Int                        @id @default(autoincrement())
  order_id            Int                        @unique(map: "order_id")
  product_name        String                     @db.VarChar(255)
  state_code          String                     @db.VarChar(100)
  first_name          String                     @db.VarChar(100)
  last_name           String                     @db.VarChar(100)
  shipping_firstname  String                     @db.VarChar(100)
  shipping_lastname   String                     @db.VarChar(100)
  email               String                     @db.VarChar(255)
  telephone           String                     @db.VarChar(50)
  quantity            String                     @db.VarChar(100)
  model               String                     @db.VarChar(100)
  shipping_city       String                     @db.VarChar(100)
  shipping_zone       String                     @db.VarChar(100)
  comment             String                     @db.Text
  date_added          DateTime?                  @default(now()) @db.DateTime(0)
  reminder_date       DateTime?                  @db.Date
  status              ks_uvki_order_status?      @default(Pending)
  remark              String                     @db.Text
  status_updated_date DateTime                   @db.DateTime(0)
  status_name         ks_uvki_order_status_name?
  tracking_number     String                     @db.VarChar(255)
  order_status_id     Int?                       @default(0)
  short_order_id      String?                    @db.VarChar(100)
  order_source        String?                    @db.VarChar(50)
}

model order_employees {
  id          Int       @id @default(autoincrement())
  employee_id String    @unique(map: "employee_id") @db.VarChar(50)
  name        String    @db.VarChar(100)
  email       String    @unique(map: "email") @db.VarChar(100)
  password    String    @db.VarChar(255)
  details     String?   @db.Text
  created_at  DateTime? @default(now()) @db.Timestamp(0)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model uvki_404s_report {
  link String   @db.VarChar(321)
  date DateTime @db.DateTime(0)

  @@ignore
}

model uvki_address {
  address_id   Int    @id @default(autoincrement())
  customer_id  Int
  firstname    String @db.VarChar(32)
  lastname     String @db.VarChar(32)
  company      String @db.VarChar(40)
  address_1    String @db.VarChar(128)
  address_2    String @db.VarChar(128)
  city         String @db.VarChar(128)
  postcode     String @db.VarChar(10)
  country_id   Int    @default(0)
  zone_id      Int    @default(0)
  custom_field String @db.Text

  @@index([customer_id], map: "customer_id")
}

model uvki_api {
  api_id        Int      @id @default(autoincrement())
  username      String   @db.VarChar(64)
